# ---- Customer invoices DB (the `invoices` table) ----
DATABASE_URL=postgresql://postgres:PASSWORD@postgresql-database-1:5432/postgres

# ---- Auth (single admin) ----
CRM_USERNAME=admin
CRM_PASSWORD=change-this-password
CRM_AUTH_TOKEN=change-this-long-random-token
# true only when served over HTTPS
CRM_COOKIE_SECURE=true

# ---- Customer reminder actions (existing n8n flow) ----
N8N_BASE_URL=https://n8n.moodmee.nl
REMINDER_WEBHOOK_SECRET=change-this-same-as-n8n

# ---- Tax / supplier invoices (the `invoice_records` table) ----
# If the tax records live in a DIFFERENT Postgres, set this. Otherwise it falls back to DATABASE_URL.
TAX_DATABASE_URL=
# Table name (default invoice_records)
TAX_INVOICE_TABLE=invoice_records
# Currency symbol shown across the tax section
CURRENCY_SYMBOL=€
# n8n intake webhook used by the Tax > Upload page
N8N_UPLOAD_WEBHOOK_URL=https://n8n.moodmee.nl/webhook/invoice-crm-upload
N8N_WEBHOOK_TOKEN=change-this-same-as-n8n

NEXT_PUBLIC_APP_NAME=Plus Tensions CRM
